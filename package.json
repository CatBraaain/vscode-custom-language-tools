{
  "name": "custom-language-config",
  "displayName": "Custom Language Config",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "categories": [
    "Formatters",
    "Linters",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "configuration",
    "custom",
    "formatter",
    "language",
    "language server",
    "lsp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CatBraaain/custom-language-config"
  },
  "publisher": "CatBraaain",
  "type": "module",
  "main": "./dist/prod/index.js",
  "scripts": {
    "build": "vp pack -d dist/prod",
    "build:test": "vp pack test/suite/*.test.ts -f cjs -d dist/test --sourcemap",
    "package": "vsce package",
    "pretest": "bun run build && bun run build:test",
    "test": "vscode-test",
    "vscode:prepublish": "bun run build"
  },
  "dependencies": {
    "string-argv": "^0.3.2",
    "vscode-languageclient": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.0.0",
    "vite-plus": "^0.1.20"
  },
  "contributes": {
    "commands": [
      {
        "command": "customLanguageConfig.restartAll",
        "title": "Restart All Language Services",
        "category": "Custom Language Config"
      }
    ],
    "configuration": {
      "title": "Custom Language Config",
      "properties": {
        "customLanguageConfig.rules": {
          "default": [],
          "description": "Rule-based configuration",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "when": {
                "type": "object",
                "properties": {
                  "langs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Target language IDs"
                  },
                  "required": {
                    "description": "Required file and content matching conditions",
                    "type": "object",
                    "properties": {
                      "file": {
                        "type": "string",
                        "description": "Required file regex pattern (e.g. package\\.json, tsconfig\\.json)"
                      },
                      "contains": {
                        "description": "Pattern that must be contained in the file (regex)",
                        "type": "string"
                      }
                    },
                    "required": [
                      "file"
                    ]
                  }
                },
                "required": [
                  "langs"
                ]
              },
              "use": {
                "type": "object",
                "properties": {
                  "lsp": {
                    "description": "Array of lsp commands",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "formatter": {
                    "description": "Array of formatter commands",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "langConfig": {
                    "description": "Language properties configuration",
                    "type": "object",
                    "properties": {
                      "comments": {
                        "type": "object",
                        "properties": {
                          "lineComment": {
                            "type": "string",
                            "description": "Line comment token"
                          },
                          "blockComment": {
                            "type": "array",
                            "prefixItems": [
                              {
                                "type": "string",
                                "description": "Block comment start token"
                              },
                              {
                                "type": "string",
                                "description": "Block comment end token"
                              }
                            ],
                            "description": "Block comment delimiters"
                          }
                        },
                        "description": "Comment configuration"
                      },
                      "brackets": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "prefixItems": [
                            {
                              "type": "string",
                              "description": "Opening bracket"
                            },
                            {
                              "type": "string",
                              "description": "Closing bracket"
                            }
                          ]
                        },
                        "description": "Bracket pairs"
                      },
                      "autoClosingPairs": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "open": {
                              "type": "string",
                              "description": "Opening character"
                            },
                            "close": {
                              "type": "string",
                              "description": "Closing character"
                            }
                          },
                          "required": [
                            "open",
                            "close"
                          ]
                        },
                        "description": "Auto-closing character pairs"
                      }
                    }
                  }
                }
              }
            },
            "required": [
              "when",
              "use"
            ]
          }
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.85.0"
  }
}
