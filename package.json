{
  "name": "custom-language-tools",
  "displayName": "Custom Language Tools",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "categories": [
    "Formatters",
    "Linters",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "configuration",
    "custom",
    "formatter",
    "language",
    "language server",
    "lsp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CatBraaain/custom-language-tools"
  },
  "publisher": "CatBraaain",
  "type": "module",
  "main": "./dist/prod/index.js",
  "scripts": {
    "build": "vp pack",
    "build:test": "vp pack test/suite/*.test.ts -f cjs -d dist/test",
    "package": "bun run build && vsce package",
    "test": "bun run build && bun run build:test && vscode-test"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "string-argv": "^0.3.2",
    "vscode-languageclient": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.0.0",
    "vite-plus": "^0.1.20"
  },
  "contributes": {
    "commands": [
      {
        "command": "customLanguageTools.restartAll",
        "title": "Restart All Language Services",
        "category": "Custom Language Tools"
      }
    ],
    "configuration": {
      "title": "Custom Language Tools",
      "properties": {
        "customLanguageTools.rules": {
          "description": "Rule-based configuration",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Name for this rule"
              },
              "document": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "language": {
                          "type": "string"
                        },
                        "scheme": {
                          "type": "string"
                        },
                        "pattern": {
                          "type": "string"
                        },
                        "notebook": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                },
                "description": "Document selector. Can be a language ID string or a DocumentFilter object. '*' matches all languages"
              },
              "condition": {
                "description": "Conditions for applying this rule",
                "type": "object",
                "properties": {
                  "when": {
                    "description": "Command(s) returning exit code 0 to enable rule. (.e.g, 'npm ls biome')",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  },
                  "whenNot": {
                    "description": "Command(s) returning exit code 1 to enable rule. (.e.g, 'grep vite-plus package.json')",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  }
                },
                "additionalProperties": false
              },
              "action": {
                "type": "object",
                "properties": {
                  "lsp": {
                    "description": "LSP server command(s). (.e.g, 'npx biome lsp-proxy')",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  },
                  "formatter": {
                    "description": "Formatter command(s). Allows ${filePath} variable. (.e.g, 'npx biome format --stdin-file-path=${filePath}')",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  }
                },
                "description": "Actions applied when rule is active",
                "additionalProperties": false
              }
            },
            "required": [
              "name",
              "document",
              "action"
            ],
            "additionalProperties": false
          }
        }
      }
    }
  },
  "activationEvents": [
    "*"
  ],
  "engines": {
    "vscode": "^1.85.0"
  }
}
