{
  "name": "custom-language-tools",
  "displayName": "Custom Language Tools",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "categories": [
    "Formatters",
    "Linters",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "configuration",
    "custom",
    "formatter",
    "language",
    "language server",
    "lsp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CatBraaain/custom-language-tools"
  },
  "publisher": "CatBraaain",
  "type": "module",
  "main": "./dist/prod/index.js",
  "scripts": {
    "build": "vp pack",
    "build:test": "vp pack test/suite/*.test.ts -f cjs -d dist/test",
    "package": "bun run build && vsce package",
    "test": "bun run build && bun run build:test && vscode-test"
  },
  "dependencies": {
    "string-argv": "^0.3.2",
    "vscode-languageclient": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.0.0",
    "vite-plus": "^0.1.20"
  },
  "contributes": {
    "commands": [
      {
        "command": "customLanguageTools.restartAll",
        "title": "Restart All Language Services",
        "category": "Custom Language Tools"
      }
    ],
    "configuration": {
      "title": "Custom Language Tools",
      "properties": {
        "customLanguageTools.rules": {
          "default": [],
          "description": "Rule-based configuration",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Name for this rule"
              },
              "condition": {
                "type": "object",
                "properties": {
                  "documentSelector": {
                    "anyOf": [
                      {
                        "anyOf": [
                          {
                            "type": "object",
                            "properties": {
                              "language": {
                                "type": "string"
                              },
                              "notebookType": {
                                "type": "string"
                              },
                              "pattern": {
                                "type": "string"
                              },
                              "scheme": {
                                "type": "string"
                              }
                            },
                            "description": "DocumentFilter"
                          },
                          {
                            "type": "string",
                            "description": "Language ID (e.g., 'javascript', 'typescript')"
                          }
                        ]
                      },
                      {
                        "type": "array",
                        "items": {
                          "anyOf": [
                            {
                              "type": "object",
                              "properties": {
                                "language": {
                                  "type": "string"
                                },
                                "notebookType": {
                                  "type": "string"
                                },
                                "pattern": {
                                  "type": "string"
                                },
                                "scheme": {
                                  "type": "string"
                                }
                              },
                              "description": "DocumentFilter"
                            },
                            {
                              "type": "string",
                              "description": "Language ID (e.g., 'javascript', 'typescript')"
                            }
                          ]
                        }
                      }
                    ],
                    "description": "Array of DocumentFilter or LanguageID for target files.\n(.e.g, ['javascript', 'typescript', { language: 'json', pattern: '**/package.json' }])\nsee details in https://code.visualstudio.com/api/references/vscode-api#DocumentFilter"
                  },
                  "when": {
                    "description": "Command executed to determine whether this rule is active (true if exit code is 0)",
                    "type": "string"
                  },
                  "whenNot": {
                    "description": "Command executed to determine whether this rule is active (true if exit code is 1)",
                    "type": "string"
                  }
                },
                "required": [
                  "documentSelector"
                ],
                "description": "Conditions for applying this rule"
              },
              "action": {
                "type": "object",
                "properties": {
                  "lsp": {
                    "description": "Array of LSP server commands",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "formatter": {
                    "description": "Array of formatter commands",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "description": "Actions to apply when conditions are met"
              }
            },
            "required": [
              "name",
              "condition",
              "action"
            ]
          }
        }
      }
    }
  },
  "activationEvents": [
    "*"
  ],
  "engines": {
    "vscode": "^1.85.0"
  }
}
